# ── Database (Railway sets DATABASE_URL automatically) ──────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/lezifx
DB_USERNAME=postgres
DB_PASSWORD=your_password

# ── JWT (generate: openssl rand -base64 64) ──────────────────────────
JWT_SECRET=change_me_min_32_characters_long

# ── AES-256 encryption key for Daraja creds (openssl rand -base64 32)
ENCRYPTION_KEY=change_me_base64_aes_256_key

# ── Super Admin bootstrap (used ONCE on first startup) ───────────────
SUPER_ADMIN_EMAIL=super@lezifx.com
SUPER_ADMIN_PASSWORD=change_me_strong_password

# ── Mail ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# ── Cloudinary ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Daraja ───────────────────────────────────────────────────────────
DARAJA_BASE_URL=https://api.safaricom.co.ke